# Copy to .env and fill in values. .env is gitignored.
# Exported shell vars override these.

# --- Required ---
LLM_API_KEY=sk-your-key-here

# --- Provider / model ---
# OpenAI (default)
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Anthropic (via OpenAI-compatible endpoint)
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-sonnet-4-5

# OpenRouter (any model)
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=anthropic/claude-sonnet-4.5

# LMStudio (local OpenAI-compatible server)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=qwen2.5-14b-instruct
# LLM_RESPONSE_FORMAT=none        # LMStudio rejects 'json_object'; omit field
# LLM_TIMEOUT_SEC=300             # local models are slow

# --- Tuning (optional) ---
LLM_MAX_TOKENS=4000
LLM_TIMEOUT_SEC=120
# LLM_RESPONSE_FORMAT=json_object   # json_object (OpenAI/Anthropic), text, or none

# --- App (optional) ---
# PORT=8080
# MAX_PDF_MB=10
# WORKERS=2
# QUEUE_CAPACITY=100
# JOB_TTL_MIN=60
